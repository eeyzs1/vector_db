# 文本分词模型
TEXT_PROCESSING_MODEL_TYPE=remote
TEXT_PROCESSING_MODEL_NAME=gpt-3.5-turbo
TEXT_PROCESSING_MODEL_PATH=./models/text
TEXT_PROCESSING_API_KEY=your_api_key
TEXT_PROCESSING_BASE_URL=https://api.openai.com/v1

# 图像分词模型
IMAGE_PROCESSING_MODEL_TYPE=local
IMAGE_PROCESSING_MODEL_NAME=clip-vit-base-patch32
IMAGE_PROCESSING_MODEL_PATH=./models/image
IMAGE_PROCESSING_API_KEY=
IMAGE_PROCESSING_BASE_URL=

# 文本清洗模型
TEXT_CLEANING_MODEL_TYPE=remote
TEXT_CLEANING_MODEL_NAME=gpt-3.5-turbo
TEXT_CLEANING_MODEL_PATH=./models/text
TEXT_CLEANING_API_KEY=your_api_key
TEXT_CLEANING_BASE_URL=https://api.openai.com/v1

# 图像清洗模型
IMAGE_CLEANING_MODEL_TYPE=local
IMAGE_CLEANING_MODEL_NAME=clip-vit-base-patch32
IMAGE_CLEANING_MODEL_PATH=./models/image
IMAGE_CLEANING_API_KEY=
IMAGE_CLEANING_BASE_URL=

# 向量嵌入模型
EMBEDDING_MODEL_TYPE=local
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH=./models/embedding
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# 向量数据库配置
VECTOR_DB_TYPE=faiss
VECTOR_DB_PATH=./data/vector_db

# 元数据存储配置
METADATA_STORAGE_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=vector_db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB配置
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DATABASE=vector_db

# 文件存储配置
FILE_STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/files

# S3配置
S3_BUCKET_NAME=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# Server API配置, 开放端口
API_PORT=8000
API_HOST=0.0.0.0

# Client API配置
BASE_URL=http://localhost:8000
API_SECRET_KEY=your-api-secret-key
API_KEY=your-initial-api-key


# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 缓存配置（memory 或 redis）
CACHE_BACKEND=memory